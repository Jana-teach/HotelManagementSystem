    "/api/Staff": {
      "post": {
        "tags": [
          "Staff"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateStaffDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateStaffDto"
              }
            },
